{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noise Desktop",
  "version": "0.1.0",
  "identifier": "com.noise.desktop",
  "build": {
    "frontendDist": "../"
  },
  "app": {
    "windows": [
      {
