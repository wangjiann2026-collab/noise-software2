{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NoiseCad",
  "version": "0.1.0",
  "identifier": "com.noisecad.desktop",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "NoiseCad — 噪声建模桌面版",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 650,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "2D/3D noise mapping CAD tool",
    "longDescription": "NoiseCad is a desktop application for acoustic noise mapping with 2D CAD editing, 3D visualisation, and noise level calculation.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": null,
      "exceptionDomain": null,
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": []
  }
}
